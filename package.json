{
  "name": "@mdaemon/process-queue",
  "version": "2.0.2",
  "type": "module",
  "description": "A lightweight, zero-dependency queue with ID-based deduplication, in-flight tracking, priority ordering, worker auto-processing, retry/DLQ, and event-driven lifecycle",
  "main": "dist/processQueue.umd.js",
  "module": "dist/processQueue.mjs",
  "browser": "dist/processQueue.umd.js",
  "common": "dist/processQueue.cjs",
  "typings": "dist/processQueue.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "jest",
    "dev-test": "jest --watchAll",
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "pub": "npm run build && npm run test && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdaemon-technologies/process-queue.git"
  },
  "keywords": [
    "queue",
    "process",
    "process-queue",
    "dedup",
    "deduplicate",
    "in-process",
    "task",
    "job",
    "unique",
    "idempotent",
    "priority-queue",
    "worker",
    "concurrency",
    "retry",
    "dead-letter",
    "event-driven",
    "typescript"
  ],
  "author": {
    "name": "MDaemon Technologies, Ltd.",
    "email": "jonathan.ehman@mdaemon.com",
    "url": "https://www.mdaemon.com"
  },
  "license": "LGPL-2.1",
  "bugs": {
    "url": "https://github.com/mdaemon-technologies/process-queue/issues"
  },
  "homepage": "https://github.com/mdaemon-technologies/process-queue#readme",
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "rollup": "^4.40.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/processQueue.d.ts",
      "import": "./dist/processQueue.mjs",
      "require": "./dist/processQueue.cjs",
      "default": "./dist/processQueue.umd.js"
    }
  }
}
